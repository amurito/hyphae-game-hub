PORT=3000
ADMIN_PASSWORD=cambia-esta-clave
SESSION_SECRET=cambia-este-secreto-largo

# Opcional para deploy gratis con Render Free + Supabase Free.
# Si estas variables existen, el servidor guarda estadisticas en Supabase
# y sirve/sube el juego desde Supabase Storage en vez del disco local.
SUPABASE_URL=https://tu-proyecto.supabase.co
SUPABASE_SERVICE_ROLE_KEY=tu-service-role-key
SUPABASE_GAME_BUCKET=game
